%%{init: {"theme": "base", "themeVariables": {"background": "#f7f3ea", "fontFamily": "Inter, ui-sans-serif, system-ui, sans-serif", "primaryTextColor": "#19170f", "primaryBorderColor": "#19170f", "lineColor": "#756f63", "edgeLabelBackground": "#f7f3ea", "clusterBkg": "#fbfaf5", "clusterBorder": "#d7d1c3"}, "flowchart": {"htmlLabels": true, "curve": "basis"}}}%%
flowchart LR
  User([User]) --> UI

  subgraph Client["Client"]
    direction TB
    UI["React + Vite<br/>Vercel frontend<br/>agenta-tau.vercel.app"]
  end

  subgraph Backend["Railway backend"]
    direction TB
    API["FastAPI app<br/>SSE event stream<br/>run controls + chat"]
    Store[("Persistent /data volume<br/>runs.sqlite<br/>checkpoints.sqlite")]
  end

  subgraph Runtime["LangGraph runtime"]
    direction TB
    Graph["StateGraph orchestrator<br/>server-side agent loop"]

    subgraph Loop["Agenta V1 lifecycle"]
      direction LR
      Plan["plan"] --> Pick["pick_task"] --> Analyze["analyze"] --> Execute["execute"] --> Route{"next?"}
      Route -->|expand| Create["create_tasks"] --> Pick
      Route -->|continue| Pick
      Route -->|finish| Summarize["summarize"]
    end
  end

  subgraph Intelligence["Tools + model"]
    direction TB
    Choice{"tool choice"}
    Reason["reason"]
    Search["search<br/>DuckDuckGo"]
    Code["code"]
    Conclude["conclude"]
    Groq["Groq LLM"]
  end

  UI -->|create run| API
  UI -->|stream events| API
  UI -->|ask about run| API
  API --> Store
  API --> Graph
  Graph --> Loop
  Analyze --> Choice
  Choice --> Reason
  Choice --> Search
  Choice --> Code
  Choice --> Conclude
  Reason --> Groq
  Search --> Groq
  Code --> Groq
  Summarize --> Groq
  API -. pause / resume / cancel .-> Store
  API -. persist chat .-> Store

  classDef user fill:#19170f,stroke:#19170f,color:#fbfaf5;
  classDef hosted fill:#eef0ed,stroke:#a9a18e,color:#19170f;
  classDef core fill:#3157d5,stroke:#19170f,color:#ffffff;
  classDef loop fill:#fbfaf5,stroke:#d7d1c3,color:#19170f;
  classDef store fill:#2e9d78,stroke:#19170f,color:#ffffff;
  classDef tool fill:#bc6829,stroke:#19170f,color:#ffffff;

  class User user;
  class UI,API hosted;
  class Graph core;
  class Plan,Pick,Analyze,Execute,Route,Create,Summarize loop;
  class Store store;
  class Choice,Reason,Search,Code,Conclude,Groq tool;
